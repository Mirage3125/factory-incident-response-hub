APP_ENV=development
BACKEND_PORT=8100
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3100
TIMEZONE=Asia/Shanghai

FRONTEND_PORT=3100
FRONTEND_API_BASE_URL=http://localhost:8100
VITE_API_TIMEOUT_MS=10000

POSTGRES_DB=factory_incidents
POSTGRES_USER=factory
POSTGRES_PASSWORD=factory_dev_password

INTERNAL_SERVICE_TOKEN=change-me-in-local-env

N8N_IMAGE=n8nio/n8n:latest
N8N_POSTGRES_DB=n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=replace-with-32-plus-character-key
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
BACKEND_INTERNAL_URL=http://backend:8100
N8N_BASE_URL=http://n8n:5678
N8N_RESUME_TIMEOUT=5
RPA_WORKER_URL=http://rpa-worker:8200
RPA_WORKER_TIMEOUT=30
RPA_WORKER_PORT=8200
RPA_ARTIFACT_ROOT=/artifacts/rpa

LEGACY_MES_URL=http://legacy-mes:8300
MES_API_URL=http://legacy-mes:8300/api/work-orders
LEGACY_MES_PORT=8300
MES_DEMO_USERNAME=mes-demo
MES_DEMO_PASSWORD=mes-password
MES_FAILURE_MODE=normal
MES_API_DELAY_SECONDS=15
RPA_HEADLESS=true
RPA_TIMEOUT_MS=10000

LLM_DEMO_MODE=true
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=demo-analyzer
LLM_TIMEOUT=10

VIBRATION_P1_THRESHOLD=8.0
TEMPERATURE_P1_THRESHOLD=90.0
DEFECT_RATE_P2_THRESHOLD=5.0
REPEAT_ESCALATION_COUNT=3
LOW_CONFIDENCE_THRESHOLD=0.6
